services:
  - type: web
    name: studygrind
    runtime: python
    buildCommand: pip install -r requirements.txt
    startCommand: gunicorn app:app
    envVars:
      - key: SECRET_KEY
        generateValue: true
      - key: DATABASE_URL
        fromDatabase:
          name: studygrind-db
          property: connectionString
      - key: RENDER
        value: true

databases:
  - name: studygrind-db
    databaseName: studygrind
    user: amz
